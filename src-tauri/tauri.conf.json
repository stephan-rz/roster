{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roster",
  "version": "0.1.0",
  "identifier": "com.roster.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:7420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Roster",
        "width": 940,
        "height": 660,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/stephan-rz/roster/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFQUZGQUIyRTYyOEYxODQKUldTRThTam1zdnF2cmlWZnVyNzJQU1JEZUJaWWRLZFhianU2bzE5eWQ4c3JJdGxVY1QrNXVscncK"
    }
  }
}
